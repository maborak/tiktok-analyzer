{
  "name": "tiktok-bot-client",
  "private": true,
  "version": "0.1.0",
  "description": "Electron desktop client for tiktok-bot. Loads the framework's web UI and adds TikTok-side capabilities (login, posting) via window.api.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "pkill -9 -f 'tiktok-bot/client|Electron Helper.*tiktok-bot/client' >/dev/null 2>&1 || true",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "package:mac": "npm run build && electron-builder --mac",
    "kill": "pkill -9 -f 'tiktok-bot/client|Electron Helper.*tiktok-bot/client' || true"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "electron": "^39.8.5",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-electron": "^0.28.8"
  },
  "build": {
    "appId": "com.maborak.tiktokbot",
    "productName": "tiktok-bot",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["dist-electron/**/*", "package.json"],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "identity": null,
      "icon": "build/icon.icns"
    }
  }
}
