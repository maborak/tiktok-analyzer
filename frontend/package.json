{
  "name": "maborak-framework-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "types:api": "openapi-typescript ../backend/openapi.snapshot.json -o src/types/api.generated.ts",
    "types:api:snapshot": "cd ../backend && python -c \"import json, api_main; json.dump(api_main.app.openapi(), open('openapi.snapshot.json', 'w'), indent=2)\" && cd ../frontend && npm run types:api"
  },
  "dependencies": {
