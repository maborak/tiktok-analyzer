# Environment Configuration for Phoveus UI
# Copy this file to .env and modify the values as needed

# API Configuration
VITE_API_BASE_URL=//192.168.0.40:9001
VITE_API_TIMEOUT=30
VITE_API_CACHE_TTL=10000

# Connectivity Configuration
VITE_CONNECTIVITY_CHECK_INTERVAL=60

# App Configuration / Branding
VITE_APP_NAME=Phoveus
VITE_APP_LEGAL_ENTITY=Phoveus
VITE_APP_DOMAIN=maborak.com
VITE_SUPPORT_EMAIL=phoveus@maborak.com
VITE_APP_VERSION=1.0.0
# Options: simple, progress_bar, skeleton, shimmer
VITE_LOADER_TYPE=shimmer
VITE_BUILD_DATE=2026-02-04T07:05:03Z
# Access Control & Build Mode
# VITE_APP_MODE: full | client | admin
#   full   - all routes (admin + user) included (default)
#   client - admin management/* routes excluded from the bundle
#   admin  - user account/billing routes excluded from the bundle
VITE_APP_MODE=client

# Admin Route Prefix Obfuscation
# Replaces /management/* with /[prefix]/* in admin routes
# Default 'management' works for local dev.
# Set a random string in production to prevent path guessing.
# e.g. VITE_ADMIN_ROUTE_PREFIX=x7k2m9  =>  /x7k2m9/users
VITE_ADMIN_ROUTE_PREFIX=lasjdhj2j3hjkh23k4h

# User/Account Route Prefix Obfuscation
# Replaces /account/* with /[prefix]/*
# Default 'account' works for local dev.
# Set a random string in production to prevent path guessing.
# e.g. VITE_USER_ROUTE_PREFIX=a9b3c1  =>  /a9b3c1/billing/orders
VITE_USER_ROUTE_PREFIX=account

# Development settings
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=info

# Production settings (uncomment and modify for production)
# VITE_API_BASE_URL=https://your-api-domain.com
# VITE_DEBUG_MODE=false
# VITE_LOG_LEVEL=error VITE_DOCKER_TAG=dev

# Captcha Configuration
# Options: "none" (disabled), "recaptcha_v3" (Google), "turnstile" (Cloudflare)
VITE_CAPTCHA_PROVIDER=turnstile
#VITE_CAPTCHA_PROVIDER=turnstile

# Google reCAPTCHA v3 Configuration
# Get your keys at: https://www.google.com/recaptcha/admin
# Required if VITE_CAPTCHA_PROVIDER=recaptcha_v3
VITE_RECAPTCHA_SITE_KEY=6Lejc1csAAAAAMcSkjVoAD4xGm1Nm6aIwhy1AUrL

# Cloudflare Turnstile Configuration
# Get your keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# Required if VITE_CAPTCHA_PROVIDER=turnstile
VITE_TURNSTILE_SITE_KEY=0x4AAAAAACSywe2vgnS_c_an